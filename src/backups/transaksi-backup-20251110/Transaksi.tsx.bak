// Backup of Transaksi.tsx on 2025-11-10
import { useState } from "react";
import { TransactionEntry } from "./TransactionEntry";
import { TransactionHistory } from "./TransactionHistory";
import { Button } from "./ui/button";

interface TransaksiProps {
  onNavigate: (page: string) => void;
}

export function Transaksi({ onNavigate }: TransaksiProps) {
  const [view, setView] = useState<'entry' | 'history'>('entry');

  return (
    <div className="flex-1 flex flex-col">
      <div className="p-4 flex items-center gap-2">
        <Button variant={view === 'entry' ? undefined : 'ghost'} size="sm" onClick={() => setView('entry')}>Catat</Button>
        <Button variant={view === 'history' ? undefined : 'ghost'} size="sm" onClick={() => setView('history')}>Riwayat</Button>
      </div>

      <div className="flex-1 overflow-auto">
        {view === 'entry' ? (
          <TransactionEntry onNavigate={onNavigate} />
        ) : (
          <TransactionHistory onNavigate={onNavigate} />
        )}
      </div>
    </div>
  );
}
